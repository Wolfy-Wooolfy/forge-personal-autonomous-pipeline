    {
      "path": "artifacts/projects/default_project/output/app/index.html",
      "content": "<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>نظام الموارد البشرية - HR System</title>\n    <style>\n        body { font-family: Arial, sans-serif; margin: 20px; background-color: #f9f9f9; }\n        header { background-color: #004080; color: white; padding: 10px 20px; text-align: center; }\n        main { margin-top: 20px; }\n        section { background: white; padding: 15px; margin-bottom: 15px; border-radius: 8px; box-shadow: 0 0 5px #ccc; }\n        h1, h2 { margin: 0 0 10px 0; }\n        label { display: block; margin: 8px 0 4px; }\n        select, button { padding: 6px 10px; font-size: 1em; }\n        .feature-list, .user-list, .security-list, .integration-list, .ui-list {\n            list-style: none;\n            padding: 0;\n        }\n        .feature-list li, .user-list li, .security-list li, .integration-list li, .ui-list li {\n            background: #e6f0ff;\n            margin: 4px 0;\n            padding: 6px 10px;\n            border-radius: 4px;\n        }\n        footer { text-align: center; margin-top: 40px; font-size: 0.9em; color: #666; }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>نظام الموارد البشرية - HR System</h1>\n    </header>\n    <main>\n        <section>\n            <h2>الميزات / Features</h2>\n            <ul class=\"feature-list\">\n                <li>إدارة الموظفين</li>\n                <li>الرواتب</li>\n                <li>الحضور</li>\n                <li>التوظيف</li>\n                <li>التدريب</li>\n                <li>تقييم الأداء</li>\n            </ul>\n        </section>\n        <section>\n            <h2>المستخدمون / Users</h2>\n            <ul class=\"user-list\">\n                <li>موظفو الموارد البشرية</li>\n                <li>المديرون</li>\n                <li>الموظفون العاديون</li>\n            </ul>\n        </section>\n        <section>\n            <h2>الأمان / Security</h2>\n            <ul class=\"security-list\">\n                <li>الامتثال للخصوصية: نعم</li>\n                <li>تشفير البيانات: نعم</li>\n                <li>التحكم في الوصول بناءً على الدور: نعم</li>\n            </ul>\n        </section>\n        <section>\n            <h2>التكامل / Integration</h2>\n            <ul class=\"integration-list\">\n                <li>التكامل مع نظام الرواتب: نعم</li>\n                <li>التكامل مع نظام الحضور: نعم</li>\n                <li>التكامل مع منصات التدريب: نعم</li>\n            </ul>\n        </section>\n        <section>\n            <h2>واجهة المستخدم / UI</h2>\n            <ul class=\"ui-list\">\n                <li>دعم متعدد اللغات: العربية، الإنجليزية</li>\n                <li>واجهة سهلة الاستخدام: نعم</li>\n            </ul>\n            <label for=\"language-select\">اختر اللغة / Select Language:</label>\n            <select id=\"language-select\" aria-label=\"Language selector\">\n                <option value=\"ar\" selected>العربية</option>\n                <option value=\"en\">English</option>\n            </select>\n        </section>\n    </main>\n    <footer>\n        <p>هذه نسخة أولية (Prototype) لنظام الموارد البشرية.</p>\n    </footer>\n    <script>\n        const langSelect = document.getElementById('language-select');\n        const content = {\n            ar: {\n                title: 'نظام الموارد البشرية - HR System',\n                featuresTitle: 'الميزات / Features',\n                features: [\n                    'إدارة الموظفين',\n                    'الرواتب',\n                    'الحضور',\n                    'التوظيف',\n                    'التدريب',\n                    'تقييم الأداء'\n                ],\n                usersTitle: 'المستخدمون / Users',\n                users: [\n                    'موظفو الموارد البشرية',\n                    'المديرون',\n                    'الموظفون العاديون'\n                ],\n                securityTitle: 'الأمان / Security',\n                security: [\n                    'الامتثال للخصوصية: نعم',\n                    'تشفير البيانات: نعم',\n                    'التحكم في الوصول بناءً على الدور: نعم'\n                ],\n                integrationTitle: 'التكامل / Integration',\n                integration: [\n                    'التكامل مع نظام الرواتب: نعم',\n                    'التكامل مع نظام الحضور: نعم',\n                    'التكامل مع منصات التدريب: نعم'\n                ],\n                uiTitle: 'واجهة المستخدم / UI',\n                ui: [\n                    'دعم متعدد اللغات: العربية، الإنجليزية',\n                    'واجهة سهلة الاستخدام: نعم'\n                ],\n                languageLabel: 'اختر اللغة / Select Language:',\n                footerText: 'هذه نسخة أولية (Prototype) لنظام الموارد البشرية.'\n            },\n            en: {\n                title: 'HR System - نظام الموارد البشرية',\n                featuresTitle: 'Features / الميزات',\n                features: [\n                    'Employee Management',\n                    'Payroll',\n                    'Attendance',\n                    'Recruitment',\n                    'Training',\n                    'Performance Evaluation'\n                ],\n                usersTitle: 'Users / المستخدمون',\n                users: [\n                    'HR Staff',\n                    'Managers',\n                    'Regular Employees'\n                ],\n                securityTitle: 'Security / الأمان',\n                security: [\n                    'Privacy Compliance: Yes',\n                    'Data Encryption: Yes',\n                    'Role-Based Access Control: Yes'\n                ],\n                integrationTitle: 'Integration / التكامل',\n                integration: [\n                    'Integrate with Payroll System: Yes',\n                    'Integrate with Attendance System: Yes',\n                    'Integrate with Training Platforms: Yes'\n                ],\n                uiTitle: 'User Interface / واجهة المستخدم',\n                ui: [\n                    'Multi-language Support: Arabic, English',\n                    'User-friendly Interface: Yes'\n                ],\n                languageLabel: 'Select Language / اختر اللغة:',\n                footerText: 'This is a prototype of the HR System.'\n            }\n        };\n\n        function updateContent(lang) {\n            document.querySelector('header h1').textContent = content[lang].title;\n            document.querySelector('section:nth-of-type(1) h2').textContent = content[lang].featuresTitle;\n            const featureList = document.querySelector('.feature-list');\n            featureList.innerHTML = '';\n            content[lang].features.forEach(f => {\n                const li = document.createElement('li');\n                li.textContent = f;\n                featureList.appendChild(li);\n            });\n\n            document.querySelector('section:nth-of-type(2) h2').textContent = content[lang].usersTitle;\n            const userList = document.querySelector('.user-list');\n            userList.innerHTML = '';\n            content[lang].users.forEach(u => {\n                const li = document.createElement('li');\n                li.textContent = u;\n                userList.appendChild(li);\n            });\n\n            document.querySelector('section:nth-of-type(3) h2').textContent = content[lang].securityTitle;\n            const securityList = document.querySelector('.security-list');\n            securityList.innerHTML = '';\n            content[lang].security.forEach(s => {\n                const li = document.createElement('li');\n                li.textContent = s;\n                securityList.appendChild(li);\n            });\n\n            document.querySelector('section:nth-of-type(4) h2').textContent = content[lang].integrationTitle;\n            const integrationList = document.querySelector('.integration-list');\n            integrationList.innerHTML = '';\n            content[lang].integration.forEach(i => {\n                const li = document.createElement('li');\n                li.textContent = i;\n                integrationList.appendChild(li);\n            });\n\n            document.querySelector('section:nth-of-type(5) h2').textContent = content[lang].uiTitle;\n            const uiList = document.querySelector('.ui-list');\n            uiList.innerHTML = '';\n            content[lang].ui.forEach(ui => {\n                const li = document.createElement('li');\n                li.textContent = ui;\n                uiList.appendChild(li);\n            });\n\n            document.querySelector('label[for=\"language-select\"]').textContent = content[lang].languageLabel;\n            document.querySelector('footer p').textContent = content[lang].footerText;\n\n            if(lang === 'ar') {\n                document.documentElement.lang = 'ar';\n                document.documentElement.dir = 'rtl';\n            } else {\n                document.documentElement.lang = 'en';\n                document.documentElement.dir = 'ltr';\n            }\n        }\n\n        langSelect.addEventListener('change', (e) => {\n            updateContent(e.target.value);\n        });\n\n        // Initialize content\n        updateContent('ar');\n    </script>\n</body>\n</html>",
      "execution_id": "ai_os_runnable_execution_1777836739493",
      "package_id": "ai_os_runnable_package_1777836739493"
    },
