      "path": "artifacts/projects/default_project/output/app/index.html",
      "content": "<!DOCTYPE html>\n<html lang=\"ar\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>سيستم خدمة عملاء - نموذج أولي</title>\n    <style>\n        body { font-family: Arial, sans-serif; direction: rtl; background-color: #f9f9f9; margin: 0; padding: 0; }\n        header { background-color: #004aad; color: white; padding: 1rem; text-align: center; }\n        main { padding: 1rem; max-width: 900px; margin: auto; }\n        h1, h2 { margin-top: 0; }\n        section { background: white; padding: 1rem; margin-bottom: 1rem; border-radius: 5px; box-shadow: 0 0 5px rgba(0,0,0,0.1); }\n        label { display: block; margin-top: 0.5rem; }\n        input, select, textarea { width: 100%; padding: 0.5rem; margin-top: 0.25rem; border: 1px solid #ccc; border-radius: 4px; }\n        button { background-color: #004aad; color: white; border: none; padding: 0.75rem 1.5rem; margin-top: 1rem; border-radius: 4px; cursor: pointer; }\n        button:hover { background-color: #00337a; }\n        .ticket-list { margin-top: 1rem; }\n        .ticket { border-bottom: 1px solid #ddd; padding: 0.5rem 0; }\n        .ticket:last-child { border-bottom: none; }\n        .role-select { margin-bottom: 1rem; }\n        .channel-badge { display: inline-block; background-color: #004aad; color: white; padding: 0.2rem 0.5rem; border-radius: 3px; margin-left: 0.3rem; font-size: 0.8rem; }\n        footer { text-align: center; font-size: 0.8rem; color: #666; margin-top: 2rem; padding-bottom: 1rem; }\n    </style>\n</head>\n<body>\n    <header>\n        <h1>سيستم خدمة عملاء - نموذج أولي</h1>\n    </header>\n    <main>\n        <section>\n            <h2>تسجيل الدخول</h2>\n            <label for=\"role\">اختر دور المستخدم:</label>\n            <select id=\"role\" class=\"role-select\">\n                <option value=\"customer\">العميل</option>\n                <option value=\"agent\">ممثلي خدمة العملاء</option>\n                <option value=\"supervisor\">المشرفين</option>\n            </select>\n        </section>\n        <section id=\"ticket-section\" style=\"display:none;\">\n            <h2>إدارة التذاكر</h2>\n            <form id=\"ticket-form\">\n                <label for=\"channel\">القناة:</label>\n                <select id=\"channel\" required>\n                    <option value=\"الهاتف\">الهاتف</option>\n                    <option value=\"البريد الإلكتروني\">البريد الإلكتروني</option>\n                    <option value=\"الدردشة الحية\">الدردشة الحية</option>\n                    <option value=\"وسائل التواصل الاجتماعي\">وسائل التواصل الاجتماعي</option>\n                </select>\n                <label for=\"subject\">موضوع التذكرة:</label>\n                <input type=\"text\" id=\"subject\" required />\n                <label for=\"description\">الوصف:</label>\n                <textarea id=\"description\" rows=\"4\" required></textarea>\n                <button type=\"submit\">إنشاء تذكرة جديدة</button>\n            </form>\n            <div class=\"ticket-list\" id=\"ticket-list\">\n                <h3>التذاكر الحالية</h3>\n                <div id=\"tickets-container\"></div>\n            </div>\n        </section>\n        <section id=\"auto-reply-section\" style=\"display:none;\">\n            <h2>الرد الآلي</h2>\n            <p>عند إنشاء تذكرة جديدة، سيتم إرسال رد آلي تلقائيًا.</p>\n        </section>\n        <section id=\"performance-report-section\" style=\"display:none;\">\n            <h2>تقارير الأداء</h2>\n            <p>عدد التذاكر الحالية: <span id=\"ticket-count\">0</span></p>\n            <p>عدد التذاكر المفتوحة: <span id=\"open-ticket-count\">0</span></p>\n            <p>عدد التذاكر المغلقة: <span id=\"closed-ticket-count\">0</span></p>\n        </section>\n    </main>\n    <footer>\n        <p>هذا النظام هو نموذج أولي بسيط لنظام خدمة عملاء متعدد القنوات.</p>\n    </footer>\n    <script>\n        (function() {\n            const roleSelect = document.getElementById('role');\n            const ticketSection = document.getElementById('ticket-section');\n            const autoReplySection = document.getElementById('auto-reply-section');\n            const performanceReportSection = document.getElementById('performance-report-section');\n            const ticketForm = document.getElementById('ticket-form');\n            const ticketsContainer = document.getElementById('tickets-container');\n            const ticketCountSpan = document.getElementById('ticket-count');\n            const openTicketCountSpan = document.getElementById('open-ticket-count');\n            const closedTicketCountSpan = document.getElementById('closed-ticket-count');\n\n            let tickets = [];\n\n            function updateUIByRole(role) {\n                if (role === 'customer') {\n                    ticketSection.style.display = 'block';\n                    autoReplySection.style.display = 'block';\n                    performanceReportSection.style.display = 'none';\n                } else if (role === 'agent') {\n                    ticketSection.style.display = 'block';\n                    autoReplySection.style.display = 'block';\n                    performanceReportSection.style.display = 'block';\n                } else if (role === 'supervisor') {\n                    ticketSection.style.display = 'block';\n                    autoReplySection.style.display = 'block';\n                    performanceReportSection.style.display = 'block';\n                } else {\n                    ticketSection.style.display = 'none';\n                    autoReplySection.style.display = 'none';\n                    performanceReportSection.style.display = 'none';\n                }\n            }\n\n            function renderTickets() {\n                ticketsContainer.innerHTML = '';\n                tickets.forEach((ticket, index) => {\n                    const div = document.createElement('div');\n                    div.className = 'ticket';\n                    div.innerHTML = `\n                        <strong>موضوع:</strong> ${ticket.subject} <span class=\"channel-badge\">${ticket.channel}</span><br>\n                        <strong>الوصف:</strong> ${ticket.description}<br>\n                        <strong>الحالة:</strong> ${ticket.status}<br>\n                        <button data-index=\"${index}\" class=\"toggle-status-btn\">تغيير الحالة</button>\n                    `;\n                    ticketsContainer.appendChild(div);\n                });\n                updatePerformanceReport();\n            }\n\n            function updatePerformanceReport() {\n                ticketCountSpan.textContent = tickets.length;\n                const openCount = tickets.filter(t => t.status === 'مفتوحة').length;\n                const closedCount = tickets.filter(t => t.status === 'مغلقة').length;\n                openTicketCountSpan.textContent = openCount;\n                closedTicketCountSpan.textContent = closedCount;\n            }\n\n            ticketForm.addEventListener('submit', function(e) {\n                e.preventDefault();\n                const channel = document.getElementById('channel').value;\n                const subject = document.getElementById('subject').value.trim();\n                const description = document.getElementById('description').value.trim();\n\n                if (!subject || !description) {\n                    alert('يرجى ملء جميع الحقول.');\n                    return;\n                }\n\n                const newTicket = {\n                    channel: channel,\n                    subject: subject,\n                    description: description,\n                    status: 'مفتوحة'\n                };\n\n                tickets.push(newTicket);\n                renderTickets();\n\n                alert('تم إنشاء التذكرة بنجاح. سيتم الرد عليك آليًا قريبًا.');\n\n                ticketForm.reset();\n            });\n\n            ticketsContainer.addEventListener('click', function(e) {\n                if (e.target.classList.contains('toggle-status-btn')) {\n                    const index = e.target.getAttribute('data-index');\n                    if (tickets[index].status === 'مفتوحة') {\n                        tickets[index].status = 'مغلقة';\n                    } else {\n                        tickets[index].status = 'مفتوحة';\n                    }\n                    renderTickets();\n                }\n            });\n\n            roleSelect.addEventListener('change', function() {\n                updateUIByRole(roleSelect.value);\n            });\n\n            // Initialize UI\n            updateUIByRole(roleSelect.value);\n            renderTickets();\n        })();\n    </script>\n</body>\n</html>\n",
      "execution_id": "ai_os_runnable_execution_1777809037483",
      "package_id": "ai_os_runnable_package_1777809037483"
    },
