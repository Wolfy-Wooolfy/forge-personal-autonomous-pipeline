{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vision Coverage Matrix Schema v1",
  "description": "Schema aligned with DOC-15 §4 mandatory matrix fields.",
  "type": "object",
  "required": [
    "timestamp_utc",
    "vision_requirements_count",
    "mapped_documents_count",
    "unmapped_vision_requirements",
    "mapping"
  ],
  "properties": {
    "timestamp_utc": { "type": "string" },
    "vision_requirements_count": { "type": "integer" },
    "mapped_documents_count": { "type": "integer" },
    "unmapped_vision_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "mapping": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "vision_clause_id",
          "requirement_type",
          "bound_stages",
          "bound_tasks",
          "artifact_proof_path",
          "verification_evidence_path",
          "coverage_status"
        ],
        "properties": {
          "vision_clause_id":         { "type": "string" },
          "source_section":           { "type": "string" },
          "requirement_type":         { "type": "string", "enum": ["MUST", "SHOULD", "OPTIONAL"] },
          "bound_stages":             { "type": "array", "items": { "type": "string" } },
          "bound_tasks":              { "type": "array", "items": { "type": "string" } },
          "artifact_proof_path":      { "type": "string" },
          "verification_evidence_path":{ "type": "string" },
          "coverage_status":          { "type": "string", "enum": ["Covered", "Partial", "Missing"] },
          "mapped_document_id":       { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
